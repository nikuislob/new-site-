generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  emailVerified Boolean  @default(true)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        Order[]
  conversations Conversation[]

  @@index([email])
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         String    @default("SUPPORT_AGENT")
  isActive     Boolean   @default(true)
  failedLogins Int       @default(0)
  lockedUntil  DateTime?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignedChats Conversation[] @relation("AssignedAgent")
  activityLogs  AdminActivityLog[]

  @@index([email])
}

model AdminActivityLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  entity    String?
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}

model Match {
  id            String   @id @default(cuid())
  slug          String   @unique
  homeTeam      String
  awayTeam      String
  homeFlag      String?
  awayFlag      String?
  stage         String
  groupName     String?
  kickoffAt     DateTime
  venueName     String
  venueCity     String
  venueState    String
  venueCapacity Int?
  coverImage    String?
  description   String?
  isFeatured    Boolean  @default(false)
  isPublished   Boolean  @default(true)
  basicStock    Int      @default(500)
  premiumStock  Int      @default(200)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderItems OrderItem[]

  @@index([kickoffAt])
  @@index([isPublished])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

/// Cash App / Apple Pay with optional {amount} template — fewer links needed.
model PaymentMethod {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  iconUrl      String?
  /// e.g. https://cash.app/$YourTag/{amount} — {amount} replaced with dollar total
  urlTemplate  String
  buttonText   String   @default("Pay Now")
  instructions String?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  overrides PaymentLinkOverride[]
  orders    Order[]
}

/// Optional fixed URL for a specific cart total (70 / 140 / 210 / 280).
model PaymentLinkOverride {
  id              String   @id @default(cuid())
  paymentMethodId String
  amountCents     Int
  paymentUrl      String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  @@unique([paymentMethodId, amountCents])
  @@index([amountCents])
}

model Order {
  id                String   @id @default(cuid())
  orderNumber       String   @unique
  userId            String?
  guestEmail        String?
  guestName         String?
  guestPhone        String?
  status            String   @default("PAYMENT_PENDING")
  paymentStatus     String   @default("PENDING")
  paymentMethodId   String?
  paymentMethodName String?
  paymentUrlUsed    String?
  /// Polapine invoice / payment link id for Cash App API reconciliation
  paymentExternalId String?
  paymentProvider   String?
  subtotalCents     Int
  totalCents        Int
  ticketCount       Int
  notes             String?
  billingCity       String?
  billingState      String?
  billingZip        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  items         OrderItem[]

  @@index([orderNumber])
  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([paymentExternalId])
}

model OrderItem {
  id            String @id @default(cuid())
  orderId       String
  matchId       String
  seatTier      String
  quantity      Int
  unitPriceCents Int
  lineTotalCents Int
  sectionLabel  String?
  matchSnapshot String

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([matchId])
}

model Conversation {
  id            String   @id @default(cuid())
  userId        String?
  guestName     String?
  guestEmail    String?
  status        String   @default("OPEN")
  assignedToId  String?
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  assignedTo AdminUser?  @relation("AssignedAgent", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages   Message[]

  @@index([status])
  @@index([lastMessageAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderType     String
  senderName     String?
  body           String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}
