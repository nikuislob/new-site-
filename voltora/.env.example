# Arena Nights Environment Configuration
# Copy this file to .env and update values for your environment

# Database (SQLite for local development)
DATABASE_URL="file:./dev.db"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STORE_NAME="Arena Nights"

# Authentication secrets (change in production — generate with: openssl rand -base64 48)
AUTH_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"
ADMIN_AUTH_SECRET="change-me-to-another-long-random-admin-secret"

# Session durations (seconds)
ADMIN_SESSION_MAX_AGE=28800

# Rate limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# File uploads
MAX_UPLOAD_SIZE_MB=5

# Optional payment webhook shared secret (if configuring automated verification)
# PAYMENT_WEBHOOK_SECRET=
