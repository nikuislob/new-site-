# PitchPass local environment
DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STORE_NAME="PitchPass"

# Generate unique 32+ byte secrets for production
AUTH_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"
ADMIN_AUTH_SECRET="change-me-to-another-long-random-admin-secret"
CUSTOMER_SESSION_MAX_AGE=604800
ADMIN_SESSION_MAX_AGE=28800
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Match synchronization. MATCH_API_URL must be the exact endpoint from your provider.
MATCH_API_URL=
MATCH_API_KEY=
CRON_SECRET=

# Cash App/provider integration. Supply exact values from your API documentation.
CASH_APP_API_BASE_URL=
CASH_APP_CREATE_PAYMENT_PATH=
CASH_APP_API_KEY=
CASH_APP_WEBHOOK_SECRET=

# Private ticket delivery
MAX_TICKET_UPLOAD_MB=10

# Optional transactional email
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM="PitchPass <noreply@pitchpass.example>"
