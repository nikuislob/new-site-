# Voltora Environment Configuration
# Copy this file to .env and update values for your environment

# Database (SQLite for local development)
DATABASE_URL="file:./dev.db"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STORE_NAME="Voltora"

# Authentication secrets (change in production — generate with: openssl rand -base64 48)
AUTH_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"
ADMIN_AUTH_SECRET="change-me-to-another-long-random-admin-secret"

# Session durations (seconds)
CUSTOMER_SESSION_MAX_AGE=604800
ADMIN_SESSION_MAX_AGE=28800

# Rate limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# File uploads
MAX_UPLOAD_SIZE_MB=5

# ggusonepay.com payment gateway (server-side only — never expose in frontend)
GGUSONE_HOST="https://www.ggusonepay.com"
GGUSONE_MCH_NO="your_merchant_id"
GGUSONE_KEY="your_merchant_key"
