# Voltora Environment Configuration
# Copy to .env and fill in secrets. Never commit real keys.

DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STORE_NAME="Voltora"

# Required auth secrets (openssl rand -base64 48)
AUTH_SECRET="change-me-customer-secret-min-32-chars"
ADMIN_AUTH_SECRET="change-me-admin-secret-min-32-chars"

CUSTOMER_SESSION_MAX_AGE=604800
ADMIN_SESSION_MAX_AGE=28800
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
MAX_UPLOAD_SIZE_MB=5

# Payment provider: auto | stripe | ggusone | external_link
PAYMENT_PROVIDER="auto"

# Stripe (recommended for Card + Apple Pay + Google Pay via Checkout)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional link/gateway adapter (server only — never expose to browser)
# GGUSONE_HOST="https://www.ggusonepay.com"
# GGUSONE_MCH_NO=
# GGUSONE_KEY=
