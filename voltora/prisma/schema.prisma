generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Upcoming football matches available for ticket sales
model Match {
  id                 String   @id @default(uuid()) @db.Uuid
  homeTeam           String   @map("home_team")
  awayTeam           String   @map("away_team")
  venue              String
  stadiumViewUrl     String   @map("stadium_view_url")
  matchDate          DateTime @map("match_date") @db.Timestamptz(6)
  standardAvailable  Int      @map("standard_available")
  premiumAvailable   Int      @map("premium_available")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  orders             Order[]

  @@index([matchDate])
  @@map("matches")
}

/// Customer ticket orders with manual Apple Pay / Cash App payment-link workflow
model Order {
  id               String   @id @default(uuid()) @db.Uuid
  matchId          String   @map("match_id") @db.Uuid
  customerEmail    String   @map("customer_email")
  customerName     String?  @map("customer_name")
  ticketType       String   @map("ticket_type") // 'standard' | 'premium'
  quantity         Int
  totalPrice       Decimal  @map("total_price") @db.Decimal(10, 2)
  paymentStatus    String   @map("payment_status") // pending_link | awaiting_payment | completed
  paymentLinkSent  String?  @map("payment_link_sent")
  assignedSeats    String[] @map("assigned_seats")
  linkWorkflow     String   @default("1_ticket") @map("link_workflow") // 1_ticket | 2_ticket
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  match            Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([paymentStatus])
  @@index([customerEmail])
  @@map("orders")
}

model AdminUser {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("admin_users")
}
