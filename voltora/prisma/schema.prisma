generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         String    @default("SUPPORT_AGENT")
  isActive     Boolean   @default(true)
  totpSecret   String?
  totpEnabled  Boolean   @default(false)
  failedLogins Int       @default(0)
  lockedUntil  DateTime?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  activityLogs       AdminActivityLog[]
  assignedChats      Conversation[]      @relation("AssignedAgent")
  verifiedPayments   Order[]             @relation("PaymentVerifier")
  auditedStatusChanges OrderStatusLog[]  @relation("StatusActor")

  @@index([email])
}

model AdminActivityLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  entity    String?
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
}

model Match {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  teamAName       String
  teamBName       String
  teamACode       String
  teamBCode       String
  teamAFlagUrl    String?
  teamBFlagUrl    String?
  matchDate       DateTime
  stadiumName     String
  city            String
  description     String?
  heroImageUrl    String?
  salesEnabled    Boolean  @default(true)
  isSoldOut       Boolean  @default(false)
  isFeatured      Boolean  @default(true)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  zones      StadiumZone[]
  categories TicketCategory[]
  orders     Order[]

  @@index([slug])
  @@index([matchDate])
  @@index([isActive])
  @@index([isFeatured])
}

model StadiumZone {
  id          String   @id @default(cuid())
  matchId     String
  categoryId  String
  code        String
  name        String
  viewingQuality String @default("STANDARD")
  svgPathId   String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  match    Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  category TicketCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([matchId, code])
  @@index([matchId])
  @@index([categoryId])
}

model TicketCategory {
  id          String   @id @default(cuid())
  matchId     String
  slug        String
  name        String
  description String
  priceCents  Int
  totalInventory Int
  reservedCount  Int   @default(0)
  soldCount      Int   @default(0)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  match        Match                 @relation(fields: [matchId], references: [id], onDelete: Cascade)
  zones        StadiumZone[]
  paymentLinks PaymentLinkMapping[]
  orderItems   OrderItem[]

  @@unique([matchId, slug])
  @@index([matchId])
  @@index([isActive])
}

model PaymentMethod {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  iconUrl      String?
  buttonText   String   @default("Pay Now")
  instructions String?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  paymentLinks PaymentLinkMapping[]
  orders       Order[]

  @@index([code])
}

model PaymentLinkMapping {
  id               String   @id @default(cuid())
  ticketCategoryId String
  quantity         Int
  paymentMethodId  String
  paymentUrl       String
  expectedAmountCents Int
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ticketCategory TicketCategory @relation(fields: [ticketCategoryId], references: [id], onDelete: Cascade)
  paymentMethod  PaymentMethod  @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  @@unique([ticketCategoryId, quantity, paymentMethodId])
  @@index([ticketCategoryId])
  @@index([paymentMethodId])
  @@index([isActive])
}

model Order {
  id                    String    @id @default(cuid())
  orderNumber           String    @unique
  accessCode            String
  matchId               String
  status                String    @default("PENDING")
  paymentStatus         String    @default("PENDING")
  ticketStatus          String    @default("NONE")
  customerName          String
  customerEmail         String
  customerPhone         String?
  paymentMethodId       String?
  paymentMethodCode     String?
  paymentMethodName     String?
  paymentUrlUsed        String?
  unitPriceCents        Int
  quantity              Int
  subtotalCents         Int
  feesCents             Int       @default(0)
  totalCents            Int
  reservationExpiresAt  DateTime?
  verifiedAt            DateTime?
  verifiedByAdminId     String?
  adminNotes            String?
  currentPage           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  match             Match              @relation(fields: [matchId], references: [id])
  paymentMethod     PaymentMethod?     @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  verifiedByAdmin   AdminUser?         @relation("PaymentVerifier", fields: [verifiedByAdminId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  tickets           Ticket[]
  conversations     Conversation[]
  statusLogs        OrderStatusLog[]

  @@index([orderNumber])
  @@index([accessCode])
  @@index([matchId])
  @@index([status])
  @@index([paymentStatus])
  @@index([customerEmail])
  @@index([reservationExpiresAt])
  @@index([createdAt])
}

model OrderItem {
  id               String  @id @default(cuid())
  orderId          String
  ticketCategoryId String?
  categoryName     String
  categorySlug     String
  zoneCode         String?
  zoneName         String?
  unitPriceCents   Int
  quantity         Int
  lineTotalCents   Int

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketCategory TicketCategory? @relation(fields: [ticketCategoryId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model OrderStatusLog {
  id             String   @id @default(cuid())
  orderId        String
  previousStatus String?
  newStatus      String
  previousPaymentStatus String?
  newPaymentStatus String?
  actorAdminId   String?
  note           String?
  createdAt      DateTime @default(now())

  order Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor AdminUser? @relation("StatusActor", fields: [actorAdminId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([createdAt])
}

model Ticket {
  id               String    @id @default(cuid())
  ticketNumber     String    @unique
  orderId          String
  qrToken          String    @unique
  status           String    @default("VALID")
  holderName       String
  categoryName     String
  zoneName         String?
  zoneCode         String?
  matchSnapshot    String
  checkedInAt      DateTime?
  checkedInBy      String?
  revokedAt        DateTime?
  revokeReason     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([qrToken])
  @@index([status])
}

model Conversation {
  id             String   @id @default(cuid())
  guestName      String?
  guestEmail     String?
  orderId        String?
  subject        String?
  tag            String?
  status         String   @default("OPEN")
  assignedToId   String?
  currentPage    String?
  lastMessageAt  DateTime @default(now())
  unreadAdmin    Int      @default(0)
  unreadCustomer Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order      Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  assignedTo AdminUser? @relation("AssignedAgent", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages   Message[]

  @@index([status])
  @@index([lastMessageAt])
  @@index([guestEmail])
  @@index([tag])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderType     String
  senderName     String
  body           String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@index([key])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ipAddress String?
  success   Boolean
  context   String   @default("admin")
  createdAt DateTime @default(now())

  @@index([email, context])
  @@index([createdAt])
}
